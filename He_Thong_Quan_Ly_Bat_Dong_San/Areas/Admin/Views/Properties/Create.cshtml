@model He_Thong_Quan_Ly_Bat_Dong_San.Models.Property

@{
    ViewData["Title"] = "Thêm Bất Động Sản Mới";
}

<div class="card card-custom p-4 mt-3 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="fw-bold" style="color: #0d1b2a;">
            <i class="bi bi-plus-square-dotted text-danger me-2"></i> 
            @ViewData["Title"]
        </h4>

        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-md-7">
                <div class="p-4 bg-light rounded-4 border border-light">

                    <h5 class="fw-bold mb-4 text-primary-custom border-bottom pb-2">
                        Thông tin cơ bản
                    </h5>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold text-dark">
                            Tên Dự Án / Tiêu đề <span class="text-danger">*</span>
                        </label>

                        <input asp-for="Title"
                               class="form-control form-control-lg border-0 shadow-sm"
                               placeholder="VD: Căn hộ cao cấp Vinhomes..." />

                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">

                        <div class="col-sm-6">
                            <label asp-for="Price" class="form-label fw-bold text-dark">
                                Giá bán (VNĐ) <span class="text-danger">*</span>
                            </label>

                            <input asp-for="Price"
                                   type="number"
                                   class="form-control form-control-lg border-0 shadow-sm text-danger fw-bold"
                                   placeholder="VD: 2500000000" />

                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="Area" class="form-label fw-bold text-dark">
                                Diện tích (m²) <span class="text-danger">*</span>
                            </label>

                            <input asp-for="Area"
                                   type="number"
                                   step="0.1"
                                   class="form-control form-control-lg border-0 shadow-sm"
                                   placeholder="VD: 75.5" />

                            <span asp-validation-for="Area" class="text-danger small"></span>
                        </div>

                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold text-dark">
                            Vị trí / Địa chỉ <span class="text-danger">*</span>
                        </label>

                        <input asp-for="Address"
                               class="form-control form-control-lg border-0 shadow-sm"
                               placeholder="Nhập địa chỉ chi tiết..." />

                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold text-dark">Mô tả chi tiết BĐS</label>
                        <textarea asp-for="Description" class="form-control shadow-sm" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                </div>
            </div>


            <!-- RIGHT -->
            <div class="col-md-5">
                <div class="p-4 bg-light rounded-4 border border-light h-100">

                    <h5 class="fw-bold mb-4 text-primary-custom border-bottom pb-2">
                        Phân loại & Hình ảnh
                    </h5>

                    <div class="mb-4">
                        <label asp-for="CategoryId"
                               class="form-label fw-bold text-dark">
                            Thuộc Danh Mục <span class="text-danger">*</span>
                        </label>

                        <select asp-for="CategoryId"
                                class="form-select form-select-lg border-0 shadow-sm fw-medium"
                                asp-items="ViewBag.CategoryId">

                            <option value="">-- Chọn danh mục --</option>

                        </select>

                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>


                    <!-- ẢNH ĐẠI DIỆN -->

                    <div class="mb-3">
                        <label asp-for="ImageUpload"
                               class="form-label fw-bold text-dark">

                            Ảnh đại diện (Bắt buộc)

                        </label>

                        <input asp-for="ImageUpload"
                               class="form-control shadow-sm"
                               type="file"
                               accept="image/*" />

                        <span asp-validation-for="ImageUpload"
                              class="text-danger small"></span>
                    </div>


                    <!-- GALLERY -->

                    <div class="mb-4 p-3 bg-light rounded-3 border border-secondary border-opacity-25">

                        <label asp-for="GalleryUploads"
                               class="form-label fw-bold text-primary-custom">

                            <i class="bi bi-images me-1"></i>
                            Album ảnh chi tiết (Tối đa 5 ảnh)

                        </label>

                        <input asp-for="GalleryUploads"
                               class="form-control shadow-sm"
                               type="file"
                               multiple
                               accept="image/*" />

                        <span asp-validation-for="GalleryUploads"
                              class="text-danger small"></span>

                        <div class="form-text text-muted small mt-2">

                            <i class="bi bi-info-circle"></i>

                            Giữ phím <strong>Ctrl</strong> để chọn nhiều ảnh cùng lúc.
                            Khách hàng sẽ trượt xem các ảnh này trong trang Chi tiết.

                        </div>

                    </div>


                    <div class="mt-5 d-grid gap-2">

                        <button type="submit"
                                class="btn text-white btn-lg fw-bold shadow"
                                style="background-color: #ff6b6b; border-radius: 12px;">

                            <i class="bi bi-cloud-arrow-up-fill me-2"></i>
                            Lưu Bất Động Sản

                        </button>

                    </div>

                </div>
            </div>

        </div>

    </form>
</div>

@section Scripts {

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
document.querySelector("input[multiple]").addEventListener("change", function () {

    if (this.files.length > 5) {
        alert("Chỉ được chọn tối đa 5 ảnh!");
        this.value = "";
    }

});
</script>

}