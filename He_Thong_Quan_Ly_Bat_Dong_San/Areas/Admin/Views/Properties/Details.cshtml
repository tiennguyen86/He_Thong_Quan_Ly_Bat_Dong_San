@model He_Thong_Quan_Ly_Bat_Dong_San.Models.Property

@{
    ViewData["Title"] = "Chi tiết Bất Động Sản";
}

<div class="card card-custom p-4 mt-3 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="fw-bold" style="color: #0d1b2a;"><i class="bi bi-info-square text-info me-2"></i> @ViewData["Title"]</h4>
        <div class="btn-group shadow-sm">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary fw-bold px-4"><i class="bi bi-pencil-square"></i> Cập nhật (Update)</a>
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4"><i class="bi bi-arrow-left"></i> Quay lại</a>
        </div>
    </div>

    <div class="row g-5 mt-2">
        <div class="col-md-5">
            <div class="position-relative rounded-4 overflow-hidden shadow-sm border">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-property.jpg" : Model.ImageUrl)" 
                     class="img-fluid w-100 object-fit-cover" style="height: 350px;" alt="@Model.Title"
                     onerror="this.src='https://placehold.co/600x400?text=No+Image'" />
                <span class="position-absolute top-0 start-0 m-3 badge bg-white text-dark shadow-sm border fs-6 px-3 py-2">
                    Mã BĐS: #@Model.Id
                </span>
            </div>
        </div>

        <div class="col-md-7">
            <h3 class="fw-bold text-primary-custom mb-3">@Model.Title</h3>
            
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="fs-4 fw-bolder text-danger">@Model.Price.ToString("N0") VNĐ</span>
                <span class="badge bg-light text-dark border px-3 py-2 fs-6"><i class="bi bi-tag-fill text-success"></i> @Model.Category?.Name</span>
            </div>

            <div class="bg-light p-4 rounded-4 border border-light mb-4">
                <div class="row g-4">
                    <div class="col-sm-6">
                        <p class="text-muted mb-1 small fw-bold">DIỆN TÍCH</p>
                        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-bounding-box-circles text-secondary"></i> @Model.Area m²</h5>
                    </div>
                    <div class="col-sm-6">
                        <p class="text-muted mb-1 small fw-bold">VỊ TRÍ</p>
                        <h6 class="fw-bold mb-0 text-dark lh-base"><i class="bi bi-geo-alt-fill text-danger"></i> @Model.Address</h6>
                    </div>
                </div>
            </div>

            <div class="alert alert-secondary border-0 rounded-4 d-flex align-items-center">
                <i class="bi bi-info-circle-fill fs-4 me-3 text-secondary"></i>
                <div>
                    <strong>Lưu ý quản trị:</strong> 
                    Đảm bảo thông tin và hình ảnh dự án luôn được cập nhật (Update) mới nhất để khách hàng nắm bắt chính xác.
                </div>
            </div>
        </div>
    </div>
</div>