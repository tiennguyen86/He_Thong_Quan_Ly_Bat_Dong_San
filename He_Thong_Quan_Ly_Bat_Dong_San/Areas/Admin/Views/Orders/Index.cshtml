@model IEnumerable<He_Thong_Quan_Ly_Bat_Dong_San.Models.Order>

@{
    ViewData["Title"] = "Quản lý Đơn đặt lịch";
}

<div class="card card-custom p-4 shadow-sm border-0 rounded-4 mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="fw-bold" style="color: #0d1b2a;"><i class="bi bi-calendar-check me-2"></i> @ViewData["Title"]</h4>
        <span class="badge bg-primary rounded-pill fs-6 px-3 py-2">Tổng: @ViewBag.TotalItems đơn</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3 text-muted">Hiện chưa có khách hàng nào đặt lịch.</h5>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle text-nowrap">
                <thead class="bg-light text-muted" style="font-size: 0.85rem;">
                    <tr>
                        <th class="py-3 ps-3">KHÁCH HÀNG</th>
                        <th class="py-3">SỐ ĐIỆN THOẠI</th>
                        <th class="py-3">NGÀY ĐẶT</th>
                        <th class="py-3">GHI CHÚ</th>
                        <th class="py-3 text-center">TRẠNG THÁI</th>
                        <th class="py-3 text-center">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-3">
                                <h6 class="fw-bold mb-0 text-primary-custom">@item.CustomerName</h6>
                                @if (item.AppUser != null)
                                {
                                    <small class="text-muted">User ID: @item.AppUser.Id.Substring(0, Math.Min(item.AppUser.Id.Length, 8))...</small>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-2 py-1 fs-6">
                                    <i class="bi bi-telephone text-success me-1"></i> @item.PhoneNumber
                                </span>
                            </td>
                            <td>
                                <span class="text-muted fw-medium">@item.OrderDate.ToString("dd/MM/yyyy")</span> <br/>
                                <small class="text-muted">@item.OrderDate.ToString("HH:mm")</small>
                            </td>
                            <td class="text-wrap text-muted small" style="max-width: 200px;">
                                @(string.IsNullOrEmpty(item.Notes) ? "-" : item.Notes)
                            </td>
                            <td class="text-center">
                                @if(item.Status == "Chờ xác nhận") 
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-hourglass-split"></i> @item.Status</span>
                                } 
                                else 
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-check2-circle"></i> @item.Status</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Xử lý đơn"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa đơn"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-end mt-4">
                <div class="d-inline-flex align-items-center bg-white rounded-pill px-3 py-2 shadow-sm border">
                    
                    <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1 })" 
                       class="text-dark text-decoration-none px-2 @(ViewBag.CurrentPage == 1 ? "disabled text-muted pe-none" : "")">
                        <i class="bi bi-chevron-left"></i>
                    </a>

                    <div class="d-flex align-items-center gap-2 mx-2">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <a href="@Url.Action("Index", new { page = i })" 
                               class="d-flex align-items-center justify-content-center text-decoration-none rounded-circle fw-bold 
                                      @(i == ViewBag.CurrentPage ? "bg-dark text-white" : "bg-transparent text-dark hover-bg-light")"
                               style="width: 32px; height: 32px; transition: 0.2s;">
                                @i
                            </a>
                        }
                    </div>

                    <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1 })" 
                       class="text-dark text-decoration-none px-2 @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled text-muted pe-none" : "")">
                        <i class="bi bi-chevron-right"></i>
                    </a>

                </div>
            </div>
        }
    }
</div>