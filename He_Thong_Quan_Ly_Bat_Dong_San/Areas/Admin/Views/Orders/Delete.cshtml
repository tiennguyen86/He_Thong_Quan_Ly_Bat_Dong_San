@model He_Thong_Quan_Ly_Bat_Dong_San.Models.Order

@{
    ViewData["Title"] = "Xác nhận Xóa Đơn";
    // Nhúng menu Admin
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml"; 
}

<div class="card shadow mb-4 border-bottom-danger">
    <div class="card-header py-3 bg-danger">
        <h6 class="m-0 font-weight-bold text-white">⚠️ CẢNH BÁO: Xóa Đơn Đặt Lịch #@Model.Id</h6>
    </div>
    <div class="card-body">
        <div class="alert alert-warning text-dark shadow-sm" role="alert">
            <h5 class="alert-heading font-weight-bold">Xác nhận thao tác!</h5>
            <p class="mb-0">Bạn có chắc chắn muốn xóa vĩnh viễn đơn đặt lịch của khách hàng <strong>@Html.DisplayFor(model => model.CustomerName)</strong> không? Hành động này không thể hoàn tác!</p>
        </div>
        
        <table class="table table-bordered table-striped mt-3">
            <tbody>
                <tr>
                    <th style="width: 250px;">Tên Khách Hàng</th>
                    <td class="text-danger"><strong>@Html.DisplayFor(model => model.CustomerName)</strong></td>
                </tr>
                <tr>
                    <th>Số Điện Thoại</th>
                    <td><strong>@Html.DisplayFor(model => model.PhoneNumber)</strong></td>
                </tr>
                <tr>
                    <th>Thời gian đặt</th>
                    <td>@Html.DisplayFor(model => model.OrderDate)</td>
                </tr>
                <tr>
                    <th>Ghi chú</th>
                    <td><i>@Html.DisplayFor(model => model.Notes)</i></td>
                </tr>
                <tr>
                    <th>Trạng thái</th>
                    <td>
                        <span class="badge bg-danger text-white" style="font-size: 14px; padding: 8px;">
                            @Html.DisplayFor(model => model.Status)
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer text-center">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger px-4 font-weight-bold">
                <i class="fas fa-trash-alt"></i> Xóa Vĩnh Viễn
            </button>
            <a asp-action="Index" class="btn btn-secondary px-4 ml-2">
                <i class="fas fa-times"></i> Hủy bỏ
            </a>
        </form>
    </div>
</div>