@model He_Thong_Quan_Ly_Bat_Dong_San.ViewModels.LoginVM

@{
    ViewData["Title"] = "Đăng nhập LuxEstate";
}

<div class="row justify-content-center mt-5 mb-5 pt-3">
    <div class="col-md-8 col-lg-5">
        <div class="card border-0 shadow-soft rounded-xl-custom overflow-hidden">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center text-primary-custom mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-box-arrow-in-right fs-2"></i>
                    </div>
                    <h3 class="fw-bold text-primary-custom">Chào mừng trở lại!</h3>
                    <p class="text-muted small">Đăng nhập để quản lý lịch hẹn và bất động sản yêu thích.</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center fw-bold"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control bg-light border-0 px-4" placeholder="name@example.com" style="border-radius: 12px; height: 60px;" />
                        <label asp-for="Email" class="text-muted ms-2">Địa chỉ Email</label>
                        <span asp-validation-for="Email" class="text-danger small ms-3"></span>
                    </div>
                    
                    <div class="position-relative mb-4">
                        <div class="form-floating">
                            <input asp-for="Password" id="passwordInput" class="form-control bg-light border-0 px-4" placeholder="Password" style="border-radius: 12px; height: 60px;" />
                            <label asp-for="Password" class="text-muted ms-2">Mật khẩu</label>
                        </div>
                        <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 text-muted toggle-password" data-target="passwordInput">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                        <span asp-validation-for="Password" class="text-danger small ms-3"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                        <div class="form-check form-switch">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label text-muted small">Ghi nhớ tôi</label>
                        </div>
                        
                        <a href="#" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal" class="text-accent fw-bold text-decoration-none">
                             <i class="bi bi-chat-dots-fill me-1"></i> Quên mật khẩu?
                        </a>
                    </div>

                    <button class="btn bg-accent text-white btn-lg w-100 fw-bold shadow-sm py-3" style="border-radius: 12px;" type="submit">
                        <i class="bi bi-shield-lock-fill fs-5 me-2"></i> Đăng nhập ngay
                    </button>
                </form>

                <div class="text-center mt-4 pt-4 border-top">
                    <p class="text-muted mb-0 small">Chưa có tài khoản? <a asp-action="Register" class="text-primary-custom fw-bold text-decoration-none">Đăng ký tại đây</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-5 pb-5">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-shield-lock-fill fs-1"></i>
                </div>
                <h4 class="fw-bold mb-3">Yêu cầu cấp lại mật khẩu</h4>
                <p class="text-muted mb-4">Để đảm bảo an toàn cho tài khoản, vui lòng liên hệ trực tiếp với Quản trị viên qua Zalo để được hỗ trợ cấp lại mật khẩu mới nhanh nhất.</p>
                
                <a href="https://zalo.me/0912574956" target="_blank" class="btn btn-primary btn-lg rounded-pill w-100 fw-bold shadow-sm">
                    <i class="bi bi-chat-dots fs-5 me-2"></i> Chat Zalo với Admin
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Script cho con mắt Ẩn/Hiện mật khẩu
        document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function() {
                const input = document.getElementById(this.getAttribute('data-target'));
                const icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('bi-eye-slash', 'bi-eye');
                } else {
                    input.type = 'password';
                    icon.classList.replace('bi-eye', 'bi-eye-slash');
                }
            });
        });
    </script>
}