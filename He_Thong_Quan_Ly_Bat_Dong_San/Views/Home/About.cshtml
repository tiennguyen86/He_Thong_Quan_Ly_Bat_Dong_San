@{
    ViewData["Title"] = "Về Chúng Tôi | LuxEstate Premium";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<style>
    .premium-about-page { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8fafc; }
    html { scroll-behavior: smooth; }
    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 2.5rem;
    }
</style>

<div class="premium-about-page pb-5">
    <div class="position-relative overflow-hidden text-white" style="background-color: #0d1b2a; padding: 6rem 0 10rem 0;">
        <div class="position-absolute" style="top: -5rem; right: -5rem; width: 30rem; height: 30rem; background-color: rgba(255, 107, 107, 0.1); border-radius: 50%; filter: blur(4rem); pointer-events: none;"></div>
        
        <div class="container position-relative z-2 text-center">
            <span class="d-inline-block px-3 py-1 mb-4 rounded-pill text-white fw-bold shadow-sm" style="background-color: #ff6b6b; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;">
                Câu chuyện của chúng tôi
            </span>
            <h1 class="display-3 fw-bolder mb-4">Kiến Tạo Di Sản<br>Bất Động Sản Cao Cấp</h1>
            <p class="lead mx-auto" style="color: #94a3b8; max-width: 700px; font-size: 1.15rem;">Hơn một thập kỷ đồng hành cùng giới tinh hoa, LuxEstate tự hào là cầu nối kiến tạo nên những giá trị sống đích thực và cơ hội đầu tư vượt thời gian.</p>
        </div>
    </div>

    <div class="container position-relative z-3" style="margin-top: -6rem;">
        
        <div class="glass-card p-4 p-md-5 shadow-lg mb-5">
            <div class="row text-center g-4">
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bolder mb-2" style="color: #0d1b2a;">10<span style="color: #ff6b6b;">+</span></h2>
                    <p class="text-muted fw-bold text-uppercase mb-0" style="letter-spacing: 1px; font-size: 0.8rem;">Năm kinh nghiệm</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bolder mb-2" style="color: #0d1b2a;">500<span style="color: #ff6b6b;">+</span></h2>
                    <p class="text-muted fw-bold text-uppercase mb-0" style="letter-spacing: 1px; font-size: 0.8rem;">Dự án cao cấp</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bolder mb-2" style="color: #0d1b2a;">2.5K</h2>
                    <p class="text-muted fw-bold text-uppercase mb-0" style="letter-spacing: 1px; font-size: 0.8rem;">Khách hàng tinh hoa</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bolder mb-2" style="color: #0d1b2a;">35<span style="color: #ff6b6b;">+</span></h2>
                    <p class="text-muted fw-bold text-uppercase mb-0" style="letter-spacing: 1px; font-size: 0.8rem;">Giải thưởng uy tín</p>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="glass-card p-5 h-100 shadow-sm transition-all hover-lift">
                    <span class="material-symbols-outlined fs-1 mb-4" style="color: #ff6b6b;">explore</span>
                    <h3 class="fw-bolder mb-3" style="color: #0d1b2a;">Sứ Mệnh</h3>
                    <p class="text-muted" style="line-height: 1.8;">Mang đến cho khách hàng những đặc quyền tối thượng trong việc sở hữu các bất động sản giá trị nhất. Chúng tôi không chỉ bán nhà, chúng tôi trao tay chìa khóa mở ra phong cách sống thượng lưu.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card p-5 h-100 shadow-sm transition-all hover-lift">
                    <span class="material-symbols-outlined fs-1 mb-4" style="color: #ff6b6b;">visibility</span>
                    <h3 class="fw-bolder mb-3" style="color: #0d1b2a;">Tầm Nhìn 2030</h3>
                    <p class="text-muted" style="line-height: 1.8;">Trở thành nền tảng công nghệ bất động sản số 1 Đông Nam Á, nơi mọi giao dịch triệu đô đều được thực hiện một cách minh bạch, an toàn và cá nhân hóa tuyệt đối qua hệ thống số của LuxEstate.</p>
                </div>
            </div>
        </div>
        
    </div>
</div>