@model He_Thong_Quan_Ly_Bat_Dong_San.Models.Property

@{
    ViewData["Title"] = "Chi tiết " + Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-7 mb-4">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm w-100" alt="@Model.Title" style="max-height: 500px; object-fit: cover;">
        </div>
        
        <div class="col-md-5">
            <h2 class="text-primary mb-3">@Model.Title</h2>
            <h3 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0") VNĐ</h3>
            
            <div class="card border-0 bg-light mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title border-bottom pb-2 mb-3"><i class="bi bi-info-circle"></i> Thông tin cơ bản</h5>
                    <p class="mb-2 fs-5"><i class="bi bi-tag text-secondary"></i> <strong>Loại BĐS:</strong> @Model.Category?.Name</p>
                    <p class="mb-2 fs-5"><i class="bi bi-arrows-fullscreen text-secondary"></i> <strong>Diện tích:</strong> @Model.Area m²</p>
                    <p class="mb-0 fs-5"><i class="bi bi-geo-alt text-secondary"></i> <strong>Địa chỉ:</strong> @Model.Address</p>
                </div>
            </div>
            
            <div class="d-grid gap-3">
                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-success btn-lg">
                    <i class="bi bi-calendar-plus"></i> Đặt lịch xem ngay
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>