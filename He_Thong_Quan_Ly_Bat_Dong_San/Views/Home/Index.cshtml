@model IEnumerable<He_Thong_Quan_Ly_Bat_Dong_San.Models.Property>

@{
    ViewData["Title"] = "Trang Chủ";
}

<style>
    .premium-home { font-family: 'Plus Jakarta Sans', 'Inter', sans-serif; background-color: #f8fafc; }
    
    /* Hiệu ứng thẻ BĐS cao cấp */
    .property-card { 
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); 
        border-radius: 1.5rem; 
        border: 1px solid rgba(0,0,0,0.03);
        background: #fff;
    }
    .property-card:hover { 
        transform: translateY(-10px); 
        box-shadow: 0 20px 40px rgba(13, 27, 42, 0.08) !important; 
    }
    
    .card-img-wrapper { border-radius: 1.5rem 1.5rem 0 0; overflow: hidden; }
    .card-hover-image { transition: transform 0.6s ease; }
    .property-card:hover .card-hover-image { transform: scale(1.08); }
    
    /* Nút & Badge - ĐÃ FIX LỖI HOVER */
    .badge-premium { background-color: rgba(255, 255, 255, 0.95); backdrop-filter: blur(4px); color: #0d1b2a; }
    
    .btn-navy { background-color: #0d1b2a; color: #fff; border: 2px solid #0d1b2a; transition: all 0.3s ease; }
    .btn-navy:hover { background-color: #fff !important; color: #0d1b2a !important; border-color: #fff !important; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(13,27,42,0.15) !important; }
    
    .btn-red { background-color: #ff6b6b; color: #fff; border: 2px solid #ff6b6b; transition: all 0.3s ease; }
    .btn-red:hover { background-color: #fff !important; color: #ff6b6b !important; border-color: #fff !important; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(255,107,107,0.25) !important; }
    
    .truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3.2rem; }
</style>

<div class="premium-home pb-5">
    
    <div class="position-relative overflow-hidden mb-5 mx-auto" style="height: 550px; border-radius: 0 0 3rem 3rem; box-shadow: 0 10px 30px rgba(13,27,42,0.1);">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" 
             class="w-100 h-100 object-fit-cover" alt="Khám phá Bất động sản cao cấp">
        
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(13,27,42,0.3) 0%, rgba(13,27,42,0.9) 100%);"></div>
        
        <div class="position-absolute top-50 start-50 translate-middle text-center w-100 px-4 z-1" style="margin-top: 2rem;">
            <span class="d-inline-block px-4 py-2 mb-4 rounded-pill text-white fw-bold shadow-sm border border-light border-opacity-25" style="background-color: rgba(255, 107, 107, 0.9); backdrop-filter: blur(5px); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase;">
                Bộ Sưu Tập Độc Quyền
            </span>
            <h1 class="display-3 fw-bolder text-white mb-4" style="text-shadow: 0 4px 12px rgba(0,0,0,0.5);">
                Khởi Nguồn Tổ Ấm Tinh Hoa
            </h1>
            <p class="lead text-light mb-0 mx-auto fw-light" style="max-width: 700px; font-size: 1.15rem; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
                Khám phá những kiệt tác bất động sản xa hoa và đáng sống nhất, được tuyển chọn khắt khe dành riêng cho giới thượng lưu.
            </p>
        </div>
    </div>

    <div class="container mb-5 pb-4">
        <div class="row gx-lg-5">
            
            <div class="col-lg-3 mb-5 mb-lg-0">
                <div class="sticky-top" style="top: 100px; z-index: 1;">
                    @await Component.InvokeAsync("CategoryMenu")
                </div>
            </div>

            <div class="col-lg-9">
                
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 bg-white p-3 rounded-pill shadow-sm border border-light">
                    <h4 class="fw-bolder mb-3 mb-md-0 m-0 px-3" style="color: #0d1b2a;">
                        @(ViewBag.CurrentCategory != null ? "Kết quả phân loại" : "Khám Phá Dự Án Mới")
                    </h4>

                    <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center m-0 pe-2">
                        <input type="hidden" name="searchString" value="@ViewBag.CurrentSearch" />
                        <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />

                        <div class="d-flex align-items-center bg-light rounded-pill px-3 py-2 border border-secondary border-opacity-10">
                            <i class="bi bi-funnel-fill text-danger me-2"></i>
                            <select name="sortOrder" class="form-select form-select-sm border-0 bg-transparent fw-bold shadow-none text-dark" style="cursor: pointer;" onchange="this.form.submit()">
                                <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentSort) ? "selected" : null)">Mới nhất</option>
                                <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">Giá: Thấp đến Cao</option>
                                <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">Giá: Cao đến Thấp</option>
                            </select>
                        </div>
                    </form>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light mt-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-light mb-4" style="width: 100px; height: 100px;">
                            <i class="bi bi-house-x text-muted opacity-50" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="text-dark fw-bold">Không tìm thấy bất động sản nào!</h5>
                        <p class="text-secondary mb-0">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
                    </div>
                }

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <article class="card h-100 property-card p-2">
                                
                                <div class="position-relative card-img-wrapper bg-light" style="aspect-ratio: 4/3;">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-house.jpg" : item.ImageUrl)"
                                         onerror="this.src='https://placehold.co/600x400?text=No+Image'"
                                         class="card-hover-image w-100 h-100 object-fit-cover"
                                         alt="@item.Title">

                                    <span class="position-absolute top-0 start-0 m-3 badge badge-premium shadow-sm rounded-pill px-3 py-2 fw-bold border" style="font-size: 0.75rem;">
                                        <span class="d-inline-block rounded-circle bg-danger me-1" style="width: 6px; height: 6px; margin-bottom: 1px;"></span>
                                        @item.Category?.Name
                                    </span>

                                    <button class="btn btn-light rounded-circle position-absolute top-0 end-0 m-3 d-flex align-items-center justify-content-center shadow-sm"
                                            style="width: 36px; height: 36px; backdrop-filter: blur(4px); background: rgba(255,255,255,0.85);" onclick="alert('Tính năng yêu thích đang phát triển!')">
                                        <i class="bi bi-heart text-danger"></i>
                                    </button>
                                </div>

                                <div class="card-body px-3 pt-4 pb-2 d-flex flex-column">
                                    <h4 class="fw-black text-danger mb-2" style="font-weight: 800;">
                                        @item.Price.ToString("N0") <span class="text-muted fs-6 fw-bold">VNĐ</span>
                                    </h4>
                                    
                                    <h6 class="fw-bold truncate-2 mb-3" style="color: #0d1b2a; font-size: 1.15rem; line-height: 1.5;" title="@item.Title">
                                        @item.Title
                                    </h6>

                                    <div class="d-flex justify-content-between text-muted small mb-4 mt-auto fw-medium bg-light p-3 rounded-4 border border-light">
                                        <span class="d-flex align-items-center">
                                            <i class="bi bi-aspect-ratio fs-5 text-dark opacity-50 me-2"></i> @item.Area m²
                                        </span>
                                        <span class="text-truncate d-flex align-items-center" style="max-width: 140px;" title="@item.Address">
                                            <i class="bi bi-geo-alt fs-5 text-dark opacity-50 me-2"></i> @item.Address
                                        </span>
                                    </div>

                                    <div class="row g-2 mt-auto">
                                        <div class="col-6">
                                            <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id"
                                               class="btn btn-navy w-100 fw-bold rounded-pill py-2" style="font-size: 0.9rem;">
                                                Chi tiết
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id"
                                               class="btn btn-red w-100 fw-bold rounded-pill py-2" style="font-size: 0.9rem;">
                                                <i class="bi bi-calendar2-check me-1"></i> Đặt lịch
                                            </a>
                                        </div>
                                    </div>
                                </div>

                            </article>
                        </div>
                    }
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <div class="mt-5 pt-3 d-flex justify-content-center">
                        <nav>
                            <ul class="pagination pagination-md gap-2 shadow-sm rounded-pill p-2 bg-white border border-light">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link rounded-circle border-0 text-dark fw-bold d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;"
                                       asp-action="Index"
                                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                                       asp-route-categoryId="@ViewBag.CurrentCategory"
                                       asp-route-searchString="@ViewBag.CurrentSearch"
                                       asp-route-sortOrder="@ViewBag.CurrentSort">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center @(i == ViewBag.CurrentPage ? "bg-dark text-white shadow" : "text-dark fw-bold")" style="width: 45px; height: 45px;"
                                           asp-action="Index"
                                           asp-route-page="@i"
                                           asp-route-categoryId="@ViewBag.CurrentCategory"
                                           asp-route-searchString="@ViewBag.CurrentSearch"
                                           asp-route-sortOrder="@ViewBag.CurrentSort">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link rounded-circle border-0 text-dark fw-bold d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;"
                                       asp-action="Index"
                                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                                       asp-route-categoryId="@ViewBag.CurrentCategory"
                                       asp-route-searchString="@ViewBag.CurrentSearch"
                                       asp-route-sortOrder="@ViewBag.CurrentSort">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }

            </div>
        </div>
    </div>

    <div class="container my-5 py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bolder" style="color: #0d1b2a;">Đặc Quyền Tại LuxEstate</h2>
            <p class="text-muted">Thiết lập tiêu chuẩn mới cho dịch vụ bất động sản cao cấp</p>
        </div>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 shadow-sm border border-light h-100 property-card">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 shadow-sm" style="width: 80px; height: 80px; background-color: rgba(255,107,107,0.1); color: #ff6b6b;">
                        <i class="bi bi-shield-check" style="font-size: 2.5rem;"></i>
                    </div>
                    <h5 class="fw-bold" style="color: #0d1b2a;">Pháp Lý Minh Bạch</h5>
                    <p class="text-muted small mb-0">100% dự án được kiểm định khắt khe về hồ sơ pháp lý trước khi giới thiệu đến nhà đầu tư.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 shadow-sm border border-light h-100 property-card">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 shadow-sm" style="width: 80px; height: 80px; background-color: rgba(255,107,107,0.1); color: #ff6b6b;">
                        <i class="bi bi-gem" style="font-size: 2.5rem;"></i>
                    </div>
                    <h5 class="fw-bold" style="color: #0d1b2a;">Danh Mục Độc Quyền</h5>
                    <p class="text-muted small mb-0">Tiếp cận những siêu phẩm bất động sản off-market không được công bố công khai.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-white rounded-4 shadow-sm border border-light h-100 property-card">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 shadow-sm" style="width: 80px; height: 80px; background-color: rgba(255,107,107,0.1); color: #ff6b6b;">
                        <i class="bi bi-headset" style="font-size: 2.5rem;"></i>
                    </div>
                    <h5 class="fw-bold" style="color: #0d1b2a;">Dịch Vụ Concierge</h5>
                    <p class="text-muted small mb-0">Hỗ trợ cá nhân hóa 24/7 từ đội ngũ chuyên gia hàng đầu trong mọi quy trình giao dịch.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="container mb-2">
        <div class="rounded-4 overflow-hidden position-relative shadow-lg" style="background-color: #0d1b2a;">
            <div class="position-absolute opacity-10" style="top: -50px; right: -50px;">
                <i class="bi bi-building-up" style="font-size: 20rem; color: #ff6b6b;"></i>
            </div>
            <div class="row align-items-center position-relative z-1 p-5">
                <div class="col-lg-8 text-center text-lg-start mb-4 mb-lg-0 text-white">
                    <h2 class="fw-black mb-3">Bạn Cần Ký Gửi Bất Động Sản?</h2>
                    <p class="lead mb-0" style="color: #94a3b8; font-size: 1.1rem;">Tiếp cận mạng lưới hơn 2,500 nhà đầu tư tinh hoa của LuxEstate để bán bất động sản của bạn với giá trị tốt nhất trong thời gian ngắn nhất.</p>
                </div>
                <div class="col-lg-4 text-center text-lg-end">
                    <a href="https://zalo.me/0912574956" target="_blank" class="btn btn-lg fw-bold px-5 py-3 rounded-pill shadow-lg transition-all btn-red">
                        <i class="bi bi-telephone-fill me-2"></i> Liên Hệ Ngay
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>