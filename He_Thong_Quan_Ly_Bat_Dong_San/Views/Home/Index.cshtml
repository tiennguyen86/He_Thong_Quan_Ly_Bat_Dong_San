@model IEnumerable<He_Thong_Quan_Ly_Bat_Dong_San.Models.Property>

@{
    ViewData["Title"] = "Trang Chủ";
}

<style>
    .property-card { transition: all 0.3s ease; }
    .property-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important; }
    .card-hover-image { transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    .property-card:hover .card-hover-image { transform: scale(1.05); }
    .truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; }
    .btn-action { border-radius: 8px; font-weight: 600; padding: 0.6rem; font-size: 0.9rem; }
</style>

<div class="container mt-4 pt-3">
    <div class="row gx-5">
        <div class="col-lg-3 mb-4">
            @await Component.InvokeAsync("CategoryMenu")
        </div>
        
        <div class="col-lg-9">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
                <h2 class="fw-bold text-primary-custom mb-3 mb-md-0">@(ViewBag.CurrentCategory ?? "Bất Động Sản Mới Nhất")</h2>
                <div class="d-flex gap-2">
                    <button class="btn btn-light border shadow-sm"><i class="bi bi-filter-right"></i> Lọc</button>
                    <select class="form-select shadow-sm" style="width: auto;">
                        <option>Mới nhất</option>
                        <option>Giá thấp đến cao</option>
                        <option>Giá cao đến thấp</option>
                    </select>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-muted">Không tìm thấy sản phẩm nào.</h5>
                </div>
            }

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <article class="card h-100 property-card border-0 rounded-xl-custom shadow-soft overflow-hidden">
                            <div class="position-relative overflow-hidden" style="aspect-ratio: 4/3;">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-house.jpg" : item.ImageUrl)" 
                                     onerror="this.src='https://placehold.co/600x400?text=No+Image'"
                                     class="card-hover-image w-100 h-100 object-fit-cover" alt="@item.Title">
                                
                                <span class="position-absolute top-0 start-0 m-3 badge bg-white text-primary-custom shadow-sm rounded-pill px-3 py-2">
                                    @item.Category?.Name
                                </span>
                                <button class="btn btn-light rounded-circle position-absolute top-0 end-0 m-3 d-flex align-items-center justify-content-center shadow-sm text-secondary" style="width: 35px; height: 35px;">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>
                            
                            <div class="card-body p-4 d-flex flex-column">
                                <h5 class="fw-bold truncate-2 mb-2" title="@item.Title">@item.Title</h5>
                                <p class="fs-4 fw-bolder text-accent mb-3">@item.Price.ToString("N0") VNĐ</p>
                                
                                <div class="d-flex gap-3 text-muted small mb-4 mt-auto">
                                    <span><i class="bi bi-aspect-ratio me-1"></i> @item.Area m²</span>
                                    <span class="text-truncate" title="@item.Address"><i class="bi bi-geo-alt me-1"></i> @item.Address</span>
                                </div>
                                
                                <div class="row g-2 pt-3 border-top">
                                    <div class="col-6">
                                        <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" 
                                           class="btn btn-outline-dark w-100 btn-action border-2 text-primary-custom">Chi tiết</a>
                                    </div>
                                    <div class="col-6">
                                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" 
                                           class="btn bg-accent w-100 btn-action">
                                           <i class="bi bi-calendar-check me-1"></i> Đặt lịch
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            </div>

            <div class="mt-5 d-flex justify-content-center">
                <nav aria-label="Page navigation">
                    <ul class="pagination gap-2">
                        <li class="page-item disabled"><a class="page-link rounded-3 border-0 shadow-sm text-muted" href="#"><i class="bi bi-chevron-left"></i></a></li>
                        <li class="page-item active"><a class="page-link rounded-3 border-0 shadow-sm bg-primary-custom" href="#">1</a></li>
                        <li class="page-item"><a class="page-link rounded-3 border-0 shadow-sm text-dark" href="#">2</a></li>
                        <li class="page-item"><a class="page-link rounded-3 border-0 shadow-sm text-dark" href="#">3</a></li>
                        <li class="page-item"><a class="page-link rounded-3 border-0 shadow-sm text-dark" href="#"><i class="bi bi-chevron-right"></i></a></li>
                    </ul>
                </nav>
            </div>

        </div>
    </div>
</div>