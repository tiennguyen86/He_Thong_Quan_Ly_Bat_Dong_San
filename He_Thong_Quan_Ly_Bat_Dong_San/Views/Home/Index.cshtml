@model IEnumerable<He_Thong_Quan_Ly_Bat_Dong_San.Models.Property>

@{
    ViewData["Title"] = "Trang Chủ";
}

<style>
    /* Hiệu ứng thẻ BĐS */
    .property-card { transition: all 0.3s ease; border-radius: 16px; border: 1px solid #f0f0f0; }
    .property-card:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important; }
    
    /* Hiệu ứng zoom ảnh */
    .card-hover-image { transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    .property-card:hover .card-hover-image { transform: scale(1.05); }
    
    /* Cắt chữ nếu tiêu đề quá dài */
    .truncate-2 { 
        display: -webkit-box; 
        -webkit-line-clamp: 2; 
        -webkit-box-orient: vertical; 
        overflow: hidden; 
        min-height: 2.8rem; /* Giữ chiều cao cố định để các thẻ bằng nhau */
    }

    /* Nút bấm Custom */
    .btn-outline-dark-custom {
        color: #0d1b2a;
        border: 1px solid #0d1b2a;
        background-color: transparent;
        transition: all 0.3s ease;
    }
    .btn-outline-dark-custom:hover { background-color: #0d1b2a; color: #ffffff; }
    .btn-danger-custom { background-color: #e63946; color: white; border: none; }
    .btn-danger-custom:hover { background-color: #d62828; color: white; }
</style>

<div class="container mt-4 pt-3 mb-5">
    <div class="row gx-5">

        <div class="col-lg-3 mb-4">
            @await Component.InvokeAsync("CategoryMenu")
        </div>

        <div class="col-lg-9">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 border-bottom pb-3">
                <h3 class="fw-bold mb-3 mb-md-0" style="color: #0d1b2a;">
                    @(ViewBag.CurrentCategory != null ? "Kết quả phân loại" : "Bất Động Sản Mới Nhất")
                </h3>

                <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
                    <input type="hidden" name="searchString" value="@ViewBag.CurrentSearch" />
                    <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />

                    <i class="bi bi-funnel text-muted fs-5"></i>
                    <select name="sortOrder" class="form-select w-auto shadow-sm border-0 bg-light fw-medium" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentSort) ? "selected" : null)">
                            Mới nhất
                        </option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">
                            Giá thấp đến cao
                        </option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">
                            Giá cao đến thấp
                        </option>
                    </select>
                </form>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-light rounded-4 mt-3">
                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486831.png" width="120" class="opacity-50 mb-3" alt="No data"/>
                    <h5 class="text-muted fw-bold">Không tìm thấy bất động sản nào!</h5>
                    <p class="text-secondary">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
                </div>
            }

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <article class="card h-100 property-card shadow-sm overflow-hidden bg-white">

                            <div class="position-relative overflow-hidden bg-light" style="aspect-ratio: 4/3;">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-house.jpg" : item.ImageUrl)"
                                     onerror="this.src='https://placehold.co/600x400?text=No+Image'"
                                     class="card-hover-image w-100 h-100 object-fit-cover"
                                     alt="@item.Title">

                                <span class="position-absolute top-0 start-0 m-3 badge bg-white text-dark shadow-sm rounded-pill px-3 py-2 fw-bold">
                                    @item.Category?.Name
                                </span>

                                <button class="btn btn-light rounded-circle position-absolute top-0 end-0 m-3 d-flex align-items-center justify-content-center shadow"
                                        style="width: 38px; height: 38px; transition: 0.2s;" onclick="alert('Tính năng yêu thích đang phát triển!')">
                                    <i class="bi bi-heart text-danger"></i>
                                </button>
                            </div>

                            <div class="card-body p-3 d-flex flex-column">
                                <h6 class="fw-bold truncate-2 mb-2 text-dark" title="@item.Title">
                                    @item.Title
                                </h6>

                                <h5 class="fw-bold text-danger mb-3">
                                    @item.Price.ToString("N0") đ
                                </h5>

                                <div class="d-flex justify-content-between text-muted small mb-3 mt-auto">
                                    <span class="fw-medium">
                                        <i class="bi bi-aspect-ratio text-secondary me-1"></i> @item.Area m²
                                    </span>
                                    <span class="text-truncate" style="max-width: 120px;" title="@item.Address">
                                        <i class="bi bi-geo-alt text-secondary me-1"></i> @item.Address
                                    </span>
                                </div>

                                <div class="d-flex gap-2 pt-3 border-top">
                                    <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-dark-custom w-50 fw-bold rounded-3 py-2" style="font-size: 0.85rem;">
                                        Chi tiết
                                    </a>
                                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id"
                                       class="btn btn-danger-custom w-50 fw-bold rounded-3 py-2" style="font-size: 0.85rem;">
                                        <i class="bi bi-calendar-check"></i> Đặt lịch
                                    </a>
                                </div>
                            </div>

                        </article>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="mt-5 d-flex justify-content-center">
                    <nav>
                        <ul class="pagination pagination-lg gap-2 shadow-sm rounded-pill px-3 py-2 bg-white">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-circle border-0 text-dark fw-bold"
                                   asp-action="Index"
                                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                                   asp-route-categoryId="@ViewBag.CurrentCategory"
                                   asp-route-searchString="@ViewBag.CurrentSearch"
                                   asp-route-sortOrder="@ViewBag.CurrentSort">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 @(i == ViewBag.CurrentPage ? "bg-dark text-white" : "text-dark fw-bold")"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-categoryId="@ViewBag.CurrentCategory"
                                       asp-route-searchString="@ViewBag.CurrentSearch"
                                       asp-route-sortOrder="@ViewBag.CurrentSort">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link rounded-circle border-0 text-dark fw-bold"
                                   asp-action="Index"
                                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                                   asp-route-categoryId="@ViewBag.CurrentCategory"
                                   asp-route-searchString="@ViewBag.CurrentSearch"
                                   asp-route-sortOrder="@ViewBag.CurrentSort">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }

        </div>
    </div>
</div>